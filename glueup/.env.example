# Copy to .env for local runs if you do not want to export variables in your shell.
#
# Google auth options, in priority order:
# 1. GOOGLE_ACCESS_TOKEN: paste a short-lived OAuth token.
# 2. GOOGLE_APPLICATION_CREDENTIALS: path to a service account JSON file.
# 3. gcloud CLI: if installed and logged in, the CLI will call `gcloud auth print-access-token`.
#
# GOOGLE_ACCESS_TOKEN=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

GLUEUP_EVENTS_FOLDER_ID=1rhIJFpQASAzxso02Gu1tvnMxXlyFiuFE
TIMEZONE=America/New_York

# Optional. Without this, copy generation uses deterministic templates.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini

# Banner image ranking uses Gemini via the same Google service account above
# (no separate key). Override the model only if needed.
# GEMINI_MODEL=gemini-2.5-flash-lite

# Glue Up browser-session auth for the internal AJAX endpoints.
# Do not commit real values. Cookies/tokens expire and should be refreshed from an authenticated browser session.
# GLUEUP_ORG_ID=5828
# GLUEUP_COOKIE=
# GLUEUP_CSRF_TOKEN=
#
# Playwright session auth (preferred for local use):
# 1. Run `npm run glueup-login` once to sign in at https://ycp.glueup.com/events/draft
# 2. create-draft will reuse the saved browser profile when env cookie/token are unset
# GLUEUP_EMAIL=
# GLUEUP_PASSWORD=
# Used by `npm run glueup-login-headless` and the Glue Up Login (Headless) GitHub Actions workflow.
# GLUEUP_SESSION_DIR=.glueup-session
